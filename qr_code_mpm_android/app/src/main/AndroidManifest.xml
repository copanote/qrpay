<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk tools:overrideLibrary="net.nshc.droidx3.library_serviceR" />
    <application
        android:name=".common.MpmApplication"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:requestLegacyExternalStorage="true"
        android:icon="@mipmap/ic_launcher"
        android:label="${appName}"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/AppTheme.NoTitleBar"
        android:usesCleartextTraffic="true">
        <activity
            android:exported="true"
            android:name=".IntroActivity"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.common.PermissionActivity"
            android:configChanges="orientation|keyboardHidden"
            android:theme="@style/dialog_activity_style"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize"></activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:configChanges="orientation|keyboardHidden"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize"></activity>
        <activity
            android:name=".ui.qrshare.QrSharePopupActivity"
            android:configChanges="orientation|keyboardHidden"
            android:theme="@style/dialog_activity_style"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize"></activity>
        <activity
            android:name=".ui.qrreader.QRReaderActivity"
            android:configChanges="orientation|keyboardHidden"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize"></activity>
        <activity
            android:name=".ui.qrscan.QRScanActivity"
            android:configChanges="orientation|keyboardHidden"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize"></activity>
        <activity
            android:name=".droidx.DroidXServiceListDel"
            android:configChanges="orientation|screenSize"
            android:theme="@android:style/Theme.NoTitleBar"></activity>
        <activity
            android:name=".droidx.AlertMessageDrg"
            android:theme="@android:style/Theme.Dialog"></activity>
        <!-- ===================================================== -->
        <!-- ==================  FCM  Start  ===================== -->
        <!-- ===================================================== -->
        <activity
            android:name=".ui.common.ReceiptActivity"
            android:configChanges="orientation|keyboardHidden"
            android:theme="@style/dialog_activity_style"
            android:windowSoftInputMode="stateAlwaysHidden|adjustResize" />
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.bccard.mpm.qrshareprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/qr_share_path" />
        </provider> <!-- service -->
        <!-- ==================  FCM  End  ===================== -->
        <!-- =================  Droid-X  Start  ================= -->
        <service
            android:name=".droidx.DroidXAddonService"
            android:exported="false"></service>
        <service
            android:name=".push.PushIntentService"
            android:exported="false" />
        <!-- =================  Droid-X  End  ================== -->
        <!-- File Share -->
        <service
            android:name=".push.PushMessagingService"
            android:permission="com.bccard.mpm.FCM_PERMISSION"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>

<!--        <service-->
<!--            android:name=".push.PushInstanceIdService"-->
<!--            android:permission="com.bccard.mpm.FCM_PERMISSION"-->
<!--            android:exported="true">-->
<!--            <intent-filter>-->
<!--                <action android:name="com.google.firebase.INSTANCE_ID_EVENT"/>-->
<!--            </intent-filter>-->
<!--        </service>-->
    </application>

    <permission android:name="com.bccard.mpm.FCM_PERMISSION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="30" />
<!--    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />-->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- suppress DeprecatedClassUsageInspection -->
    <uses-permission android:name="android.permission.GET_TASKS" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
</manifest>